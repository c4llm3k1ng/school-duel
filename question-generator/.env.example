# Kopiere diese Datei zu ".env" und trage deine echten Werte ein.

# ── KI-Anbieter (mindestens einer) ───────────────────────────
# Gemini (günstig/teils kostenlos – empfohlen für die Masse)
# Key holen: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Anthropic / Claude (teurer, Top-Qualität)
# Key holen: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Firebase-Anmeldung (nur nötig, um in die DB zu schreiben) ─
# Dein normales Spiel-Login (Benutzername + Passwort), mit dem du
# dich auch in der App anmeldest. Wird nur lokal verwendet.
# Bei --dry-run nicht erforderlich.
FIREBASE_USERNAME=deinBenutzername
FIREBASE_PASSWORD=deinPasswort
